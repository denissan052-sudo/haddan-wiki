---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Энциклопедия мира Хаддан' } = Astro.props;
---

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} — Haddan Wiki</title>
    <meta name="description" content={description}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Noto+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style is:global>
        body { font-family: 'Noto Sans', sans-serif; background: #0a0a0f; color: #e8e6e1; }
        .font-cinzel { font-family: 'Cinzel', serif; }
        .section-tag { display: inline-block; padding: 4px 14px; background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2); border-radius: 100px; font-size: 12px; font-weight: 600; color: #c9a84c; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 16px; }
        .card { background: #1a1a25; border: 1px solid #2a2a3a; border-radius: 12px; padding: 24px; transition: all 0.3s ease; }
        .card:hover { transform: translateY(-4px); border-color: #3a3a50; box-shadow: 0 4px 20px rgba(0,0,0,0.5); }
        .btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; background: linear-gradient(135deg, #9a7d3a, #c9a84c); color: #0a0a0f; font-weight: 600; border-radius: 8px; transition: all 0.2s; border: none; cursor: pointer; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 25px rgba(201,168,76,0.4); }
        .btn-outline { display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; background: transparent; border: 1px solid #3a3a50; color: #a0a0a0; font-weight: 600; border-radius: 8px; transition: all 0.2s; cursor: pointer; }
        .btn-outline:hover { border-color: #c9a84c; color: #e0c06e; }
        .btn-danger { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: rgba(196,74,74,0.1); border: 1px solid rgba(196,74,74,0.3); color: #c44a4a; font-weight: 600; border-radius: 8px; transition: all 0.2s; cursor: pointer; }
        .btn-danger:hover { background: rgba(196,74,74,0.2); }
        .btn-success { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: rgba(90,154,90,0.1); border: 1px solid rgba(90,154,90,0.3); color: #5a9a5a; font-weight: 600; border-radius: 8px; transition: all 0.2s; cursor: pointer; }
        .btn-success:hover { background: rgba(90,154,90,0.2); }
        .hero-bg { background: radial-gradient(ellipse at 20% 50%, rgba(201,168,76,0.08) 0%, transparent 50%), radial-gradient(ellipse at 80% 20%, rgba(90,90,170,0.06) 0%, transparent 50%), radial-gradient(ellipse at 50% 80%, rgba(122,90,170,0.05) 0%, transparent 50%); }
        .stars { position: absolute; inset: 0; background-image: radial-gradient(2px 2px at 20px 30px, rgba(255,255,255,0.3), transparent), radial-gradient(2px 2px at 40px 70px, rgba(255,255,255,0.2), transparent), radial-gradient(1px 1px at 90px 40px, rgba(255,255,255,0.15), transparent); background-size: 500px 200px; animation: starsMove 60s linear infinite; opacity: 0.4; }
        @keyframes starsMove { 0% { transform: translateY(0); } 100% { transform: translateY(-200px); } }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

        /* Markdown content */
        .prose h1 { font-family: 'Cinzel', serif; color: #e8e6e1; font-size: 2.25rem; font-weight: 700; margin-bottom: 1rem; }
        .prose h2 { font-family: 'Cinzel', serif; color: #c9a84c; font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; }
        .prose h3 { font-family: 'Cinzel', serif; color: #e0c06e; font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.5rem; }
        .prose p { color: #a0a0a0; line-height: 1.75; margin-bottom: 1rem; }
        .prose ul { list-style-type: disc; padding-left: 1.5rem; color: #a0a0a0; margin-bottom: 1rem; }
        .prose ol { list-style-type: decimal; padding-left: 1.5rem; color: #a0a0a0; margin-bottom: 1rem; }
        .prose li { margin-bottom: 0.25rem; }
        .prose strong { color: #e8e6e1; }
        .prose a { color: #c9a84c; text-decoration: none; }
        .prose a:hover { color: #e0c06e; text-decoration: underline; }
        .prose table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
        .prose th { background: #1a1a25; color: #c9a84c; padding: 0.75rem; text-align: left; border: 1px solid #2a2a3a; font-family: 'Cinzel', serif; }
        .prose td { padding: 0.75rem; border: 1px solid #2a2a3a; color: #a0a0a0; }
        .prose tr:nth-child(even) { background: #12121a; }
        .prose blockquote { border-left: 3px solid #c9a84c; padding-left: 1rem; margin: 1rem 0; color: #a0a0a0; font-style: italic; }
        .prose code { background: #1a1a25; padding: 0.2rem 0.4rem; border-radius: 4px; color: #e0c06e; font-size: 0.9em; }
        .prose pre { background: #12121a; padding: 1rem; border-radius: 8px; overflow-x: auto; border: 1px solid #2a2a3a; }

        /* Form styles */
        .form-group { margin-bottom: 1.5rem; }
        .form-label { display: block; font-size: 14px; font-weight: 500; color: #a0a0a0; margin-bottom: 0.5rem; }
        .form-input { width: 100%; padding: 12px 16px; background: #12121a; border: 1px solid #2a2a3a; border-radius: 8px; color: #e8e6e1; font-size: 14px; transition: all 0.2s; }
        .form-input:focus { outline: none; border-color: #c9a84c; box-shadow: 0 0 0 3px rgba(201,168,76,0.1); }
        .form-textarea { width: 100%; padding: 12px 16px; background: #12121a; border: 1px solid #2a2a3a; border-radius: 8px; color: #e8e6e1; font-size: 14px; min-height: 200px; resize: vertical; font-family: monospace; transition: all 0.2s; }
        .form-textarea:focus { outline: none; border-color: #c9a84c; box-shadow: 0 0 0 3px rgba(201,168,76,0.1); }
        .form-select { width: 100%; padding: 12px 16px; background: #12121a; border: 1px solid #2a2a3a; border-radius: 8px; color: #e8e6e1; font-size: 14px; cursor: pointer; }
        .form-select:focus { outline: none; border-color: #c9a84c; }

        /* Admin panel */
        .admin-bar { background: rgba(90,154,90,0.1); border: 1px solid rgba(90,154,90,0.2); border-radius: 8px; padding: 12px 16px; margin-bottom: 24px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
        .admin-bar-text { color: #5a9a5a; font-size: 14px; font-weight: 500; }

        /* Modal */
        .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 100; display: flex; align-items: center; justify-content: center; padding: 20px; }
        .modal-content { background: #1a1a25; border: 1px solid #2a2a3a; border-radius: 16px; max-width: 800px; width: 100%; max-height: 90vh; overflow-y: auto; padding: 32px; }
        .modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
        .modal-title { font-family: 'Cinzel', serif; font-size: 1.5rem; font-weight: 700; color: #e8e6e1; }
        .modal-close { width: 36px; height: 36px; border-radius: 8px; background: #12121a; border: 1px solid #2a2a3a; color: #a0a0a0; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 18px; }
        .modal-close:hover { color: #e0c06e; border-color: #c9a84c; }
    </style>
</head>
<body class="antialiased">
    <slot />
</body>
</html>
