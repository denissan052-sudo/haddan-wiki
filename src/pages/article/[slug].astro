---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getArticleBySlug, isEditor } from '../lib/supabase.js';

const { slug } = Astro.params;

let article = null;
let error = null;
let editor = false;

try {
  article = await getArticleBySlug(slug);
  try { editor = await isEditor(); } catch(e) { editor = false; }
} catch (e) {
  error = e.message;
}

const sectionNames = {
  mechanics: 'Механика',
  magic: 'Магия',
  events: 'Ивенты',
  dungeons: 'Подземелья',
  items: 'Предметы',
  classes: 'Классы',
};
---

<Layout title={article?.title || 'Статья не найдена'}>
    <Header />

    <article class="pt-28 pb-16 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
        {error || !article ? (
            <div class="text-center py-20">
                <div class="w-20 h-20 rounded-full bg-haddan-card border border-haddan-border flex items-center justify-center text-4xl mx-auto mb-4">😕</div>
                <h2 class="font-cinzel text-xl font-semibold text-haddan-text mb-2">Статья не найдена</h2>
                <p class="text-haddan-text-secondary">{error || 'Статья была удалена или ещё не создана.'}</p>
                <a href="/haddan-wiki/" class="btn-primary mt-6">На главную</a>
            </div>
        ) : (
            <div>
                <!-- Breadcrumbs -->
                <div class="flex items-center gap-3 mb-8 text-sm">
                    <a href="/haddan-wiki/" class="text-haddan-muted hover:text-haddan-gold-light transition-colors">Главная</a>
                    <span class="text-haddan-muted">/</span>
                    <a href={`/haddan-wiki/${article.section}`} class="text-haddan-muted hover:text-haddan-gold-light transition-colors">{sectionNames[article.section] || article.section}</a>
                    <span class="text-haddan-muted">/</span>
                    <span class="text-haddan-gold">{article.title}</span>
                </div>

                <!-- Admin Panel -->
                {editor && (
                    <div class="admin-bar mb-8">
                        <span class="admin-bar-text">👑 Режим редактора</span>
                        <button id="edit-article-btn" class="btn-success text-sm py-2 px-4">✏️ Редактировать</button>
                        <button id="delete-article-btn" class="btn-danger text-sm py-2 px-4">🗑️ Удалить</button>
                    </div>
                )}

                <!-- Article Header -->
                <div class="mb-10">
                    <div class="flex flex-wrap items-center gap-3 mb-4">
                        {article.tags?.map(tag => (
                            <span class="px-3 py-1 rounded-full text-xs font-medium border bg-haddan-gold/10 text-haddan-gold border-haddan-gold/20">{tag}</span>
                        ))}
                    </div>
                    <h1 class="font-cinzel text-3xl md:text-4xl font-bold text-haddan-text mb-4">{article.title}</h1>
                    {article.description && <p class="text-lg text-haddan-text-secondary">{article.description}</p>}
                    <div class="flex items-center gap-4 mt-4 text-sm text-haddan-muted">
                        <span>📅 {new Date(article.updated_at).toLocaleDateString('ru-RU')}</span>
                        {article.status === 'draft' && <span class="px-2 py-1 rounded bg-haddan-orange/10 text-haddan-orange text-xs">Черновик</span>}
                    </div>
                </div>

                <!-- Article Content -->
                <div class="prose max-w-none" id="article-content-display">
                    <div class="text-haddan-text-secondary">{article.content}</div>
                </div>

                <!-- Article Footer -->
                <div class="mt-16 pt-8 border-t border-haddan-border">
                    <div class="flex items-center justify-between">
                        <a href={`/haddan-wiki/${article.section}`} class="btn-outline text-sm py-2 px-4">← Назад в раздел</a>
                        <a href="https://forum.haddan.ru" target="_blank" class="text-sm text-haddan-muted hover:text-haddan-gold-light transition-colors">Обсудить на форуме →</a>
                    </div>
                </div>
            </div>
        )}
    </article>

    <!-- Edit Modal -->
    {editor && article && (
        <div id="edit-modal" class="modal-overlay hidden">
            <div class="modal-content" style="max-width: 900px;">
                <div class="modal-header">
                    <h2 class="modal-title">Редактировать статью</h2>
                    <button id="close-edit-modal" class="modal-close">×</button>
                </div>
                <form id="edit-form" class="space-y-4">
                    <input type="hidden" id="edit-id" value={article.id}>
                    <div class="form-group">
                        <label class="form-label">Название</label>
                        <input type="text" id="edit-title" class="form-input" value={article.title} required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">URL (slug)</label>
                        <input type="text" id="edit-slug" class="form-input" value={article.slug} required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Описание</label>
                        <input type="text" id="edit-description" class="form-input" value={article.description}>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Раздел</label>
                        <select id="edit-section" class="form-select">
                            <option value="mechanics" selected={article.section === 'mechanics'}>Механика</option>
                            <option value="magic" selected={article.section === 'magic'}>Магия</option>
                            <option value="events" selected={article.section === 'events'}>Ивенты</option>
                            <option value="dungeons" selected={article.section === 'dungeons'}>Подземелья</option>
                            <option value="items" selected={article.section === 'items'}>Предметы</option>
                            <option value="classes" selected={article.section === 'classes'}>Классы</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Теги (через запятую)</label>
                        <input type="text" id="edit-tags" class="form-input" value={article.tags?.join(', ') || ''}>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Статус</label>
                        <select id="edit-status" class="form-select">
                            <option value="draft" selected={article.status === 'draft'}>Черновик</option>
                            <option value="published" selected={article.status === 'published'}>Опубликовано</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Контент (Markdown)</label>
                        <textarea id="edit-content" class="form-textarea" style="min-height: 300px;" required>{article.content}</textarea>
                    </div>
                    <div class="flex gap-3">
                        <button type="submit" class="btn-primary">Сохранить изменения</button>
                        <button type="button" id="cancel-edit" class="btn-outline">Отмена</button>
                    </div>
                </form>
                <div id="edit-error" class="mt-4 p-3 bg-haddan-red/10 border border-haddan-red/30 rounded-lg text-haddan-red text-sm hidden"></div>
            </div>
        </div>
    )}

    <Footer />
</Layout>

{editor && article && (
    <script>
        import { updateArticle, deleteArticle } from '../lib/supabase.js';

        const editBtn = document.getElementById('edit-article-btn');
        const deleteBtn = document.getElementById('delete-article-btn');
        const editModal = document.getElementById('edit-modal');
        const closeEdit = document.getElementById('close-edit-modal');
        const cancelEdit = document.getElementById('cancel-edit');
        const editForm = document.getElementById('edit-form');
        const editError = document.getElementById('edit-error');

        editBtn?.addEventListener('click', () => {
            editModal.classList.remove('hidden');
        });

        deleteBtn?.addEventListener('click', async () => {
            if (!confirm('Удалить статью? Это действие нельзя отменить.')) return;
            try {
                await deleteArticle(document.getElementById('edit-id').value);
                window.location.href = '/haddan-wiki/';
            } catch (err) {
                alert('Ошибка: ' + err.message);
            }
        });

        closeEdit?.addEventListener('click', () => editModal.classList.add('hidden'));
        cancelEdit?.addEventListener('click', () => editModal.classList.add('hidden'));
        editModal?.addEventListener('click', (e) => { if (e.target === editModal) editModal.classList.add('hidden'); });

        editForm?.addEventListener('submit', async (e) => {
            e.preventDefault();
            try {
                const id = document.getElementById('edit-id').value;
                const article = {
                    title: document.getElementById('edit-title').value,
                    slug: document.getElementById('edit-slug').value,
                    description: document.getElementById('edit-description').value,
                    section: document.getElementById('edit-section').value,
                    content: document.getElementById('edit-content').value,
                    status: document.getElementById('edit-status').value,
                    tags: document.getElementById('edit-tags').value.split(',').map(t => t.trim()).filter(Boolean),
                };
                await updateArticle(id, article);
                window.location.reload();
            } catch (err) {
                editError.textContent = err.message;
                editError.classList.remove('hidden');
            }
        });
    </script>
)}
